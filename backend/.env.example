# ----------------------------------------------------------------
# ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to ".env" and fill in your real values.
# NEVER commit the actual ".env" file to version control.
# ----------------------------------------------------------------

# PostgreSQL connection string (Supabase, Neon, or local Postgres)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/scrap_market?schema=public"

# Server port
PORT=5000

# JWT secret - use a long random string in production
# Generate one with: openssl rand -base64 32
JWT_SECRET="replace-this-with-a-long-random-secret-string"

# JWT token expiry (e.g. "1h", "7d")
JWT_EXPIRES_IN="7d"

# Bcrypt salt rounds (10-12 recommended)
BCRYPT_SALT_ROUNDS=10

# Allowed frontend origin for CORS
CLIENT_URL="http://localhost:3000"
